{
  "name": "fin-sh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fin.sh — Nexus + Apollo GraphQL + MongoDB link shortener. Nexus (@nexus_js/*) installs from the npm registry (semver), not workspace: links.",
  "packageManager": "pnpm@9.14.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "predev": "node ./scripts/check-node-modules.mjs",
    "dev": "concurrently -k -n api,web -c blue,magenta \"pnpm --filter fin-sh-api dev\" \"node --env-file-if-exists=.env ./node_modules/@nexus_js/cli/dist/bin.js dev --port 3050\"",
    "dev:web": "node --env-file-if-exists=.env ./node_modules/@nexus_js/cli/dist/bin.js dev --port 3050",
    "prebuild": "node ./scripts/check-node-modules.mjs",
    "build": "node --env-file-if-exists=.env ./node_modules/@nexus_js/cli/dist/bin.js build",
    "prestart": "node ./scripts/check-node-modules.mjs",
    "start": "node --env-file-if-exists=.env ./node_modules/@nexus_js/cli/dist/bin.js start --port 3050",
    "precheck": "node ./scripts/check-node-modules.mjs",
    "check": "node ./node_modules/@nexus_js/cli/dist/bin.js check",
    "audit": "node ./node_modules/@nexus_js/cli/dist/bin.js audit"
  },
  "dependencies": {
    "@nexus_js/head": "^0.7.4",
    "@nexus_js/runtime": "^0.7.4",
    "@nexus_js/serialize": "^0.7.4",
    "@nexus_js/server": "^0.7.4",
    "qr-code-styling": "^1.9.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@nexus_js/audit": "^0.7.4",
    "@nexus_js/cli": "^0.7.4",
    "@nexus_js/compiler": "^0.7.4",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.1.0",
    "typescript": "^5.5.0"
  }
}
