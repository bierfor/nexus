{
  "name": "nexus-workspace",
  "version": "0.9.21",
  "private": true,
  "description": "Nexus — full-stack framework: islands-first SSR, Svelte 5 runes, server actions, file-based routes",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm -r --filter './packages/*' --parallel dev",
    "dev:paylinks": "pnpm --filter paylinks-saas dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "studio": "nexus studio",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "release": "pnpm build && pnpm publish -r --filter './packages/*' --filter '!nexus-js' --filter '!nexus_js' --access public --no-git-checks --report-summary",
    "release:safe": "pnpm build && pnpm test && pnpm publish -r --filter './packages/*' --filter '!nexus-js' --filter '!nexus_js' --access public --no-git-checks --report-summary",
    "publish:npm": "pnpm release",
    "publish:package": "bash scripts/publish-package.sh",
    "release:package": "node scripts/release-package.mjs",
    "version:framework": "node scripts/bump-framework-version.mjs"
  },
  "devDependencies": {
    "@nexus_js/cli": "workspace:^",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.0"
}
