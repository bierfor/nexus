{
  "name": "@nexus_js/server",
  "version": "0.9.3",
  "description": "Nexus Node HTTP server — SSR, server actions, islands & assets (middleware lives in @nexus_js/middleware for edge runtimes)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./actions": {
      "import": "./dist/actions.js",
      "types": "./dist/actions.d.ts"
    },
    "./context": {
      "import": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./inspector": {
      "import": "./dist/inspector.js",
      "types": "./dist/inspector.d.ts"
    },
    "./devradar": {
      "import": "./dist/devradar.js",
      "types": "./dist/devradar.d.ts"
    },
    "./handler": {
      "import": "./dist/handler.js",
      "types": "./dist/handler.d.ts"
    },
    "./streaming": {
      "import": "./dist/streaming.js",
      "types": "./dist/streaming.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexus_js/assets": "workspace:*",
    "@nexus_js/compiler": "workspace:*",
    "@nexus_js/connect": "workspace:*",
    "@nexus_js/router": "workspace:*",
    "@nexus_js/security": "workspace:*",
    "@nexus_js/serialize": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "homepage": "https://nexusjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bierfor/nexus.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/bierfor/nexus/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bierfor084"
  },
  "keywords": [
    "nexus",
    "framework",
    "full-stack",
    "svelte",
    "islands",
    "ssr",
    "vite",
    "server-actions"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
