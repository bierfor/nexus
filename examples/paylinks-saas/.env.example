# PayLinks SaaS Environment Variables

# Database
DATABASE_URL="file:./dev.db"

# Nexus Core
NEXUS_SECRET="your-secret-key-at-least-32-characters-long-for-production"
NEXUS_PORT=4000

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# JWT for GraphQL API
JWT_SECRET="another-32-character-secret-for-jwt-signing"

# S3 for QR codes (optional, defaults to data URLs)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=paylinks-qr-codes

# Email (optional, for payment confirmations)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG....
# SMTP_FROM=noreply@paylinks.example.com
