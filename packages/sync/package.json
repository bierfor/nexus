{
  "name": "@nexus_js/sync",
  "version": "0.9.19",
  "description": "Nexus Local-First Sync — IndexedDB engine ($localSync) + Byte-Mirror prototype (SQLite WASM worker / OPFS)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./workers/sqlite-sync.worker.js": "./dist/workers/sqlite-sync.worker.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nexus",
    "local-first",
    "sync",
    "indexeddb",
    "offline",
    "framework",
    "full-stack",
    "svelte",
    "islands",
    "ssr",
    "vite",
    "server-actions"
  ],
  "license": "MIT",
  "homepage": "https://nexusjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bierfor/nexus.git",
    "directory": "packages/sync"
  },
  "bugs": {
    "url": "https://github.com/bierfor/nexus/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bierfor084"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.48.0-build1"
  }
}
