{
  "name": "@nexus_js/testing",
  "version": "0.9.10",
  "description": "Nexus testing utilities — render .nx components in SSR and client mode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vitest": {
      "import": "./dist/vitest.js",
      "types": "./dist/vitest.d.ts"
    },
    "./playwright": {
      "import": "./dist/playwright.js",
      "types": "./dist/playwright.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexus_js/compiler": "workspace:*",
    "@nexus_js/runtime": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "homepage": "https://nexusjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bierfor/nexus.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/bierfor/nexus/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bierfor084"
  },
  "keywords": [
    "nexus",
    "framework",
    "full-stack",
    "svelte",
    "islands",
    "ssr",
    "vite",
    "server-actions"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
