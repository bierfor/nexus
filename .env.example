# Nexus.js Production Environment Variables
# Copy this file to .env and fill in your values

# ────────────────────────────────────────────────────────────────────────────
# Core Nexus Configuration
# ────────────────────────────────────────────────────────────────────────────

# Secret for signing sessions, CSRF tokens, and action signatures
# Generate: openssl rand -base64 32
NEXUS_SECRET=your-secret-key-minimum-32-characters

# Port to run the server on
NEXUS_PORT=3000

# Build ID (set by CI/CD, e.g. git SHA)
NEXUS_BUILD_ID=local

# Expose detailed errors in responses (NEVER set to true in production)
# NEXUS_EXPOSE_ERRORS=false

# ────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://nexus:changeme@localhost:5432/nexus_production

# PostgreSQL password (for docker-compose)
POSTGRES_PASSWORD=changeme

# ────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ────────────────────────────────────────────────────────────────────────────

# Redis URL for rate limiting and caching
REDIS_URL=redis://:changeme@localhost:6379

# Redis password (for docker-compose)
REDIS_PASSWORD=changeme

# ────────────────────────────────────────────────────────────────────────────
# Payment Gateway (PayLinks SaaS)
# ────────────────────────────────────────────────────────────────────────────

# Stripe secret key
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ────────────────────────────────────────────────────────────────────────────
# Email Service (optional)
# ────────────────────────────────────────────────────────────────────────────

# SMTP configuration for transactional emails
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

# ────────────────────────────────────────────────────────────────────────────
# AWS S3 (for file uploads, QR codes, etc.)
# ────────────────────────────────────────────────────────────────────────────

# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=nexus-uploads

# ────────────────────────────────────────────────────────────────────────────
# Monitoring & Logging
# ────────────────────────────────────────────────────────────────────────────

# Sentry DSN for error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Log level (debug, info, warn, error)
# LOG_LEVEL=info
