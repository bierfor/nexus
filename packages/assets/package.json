{
  "name": "@nexus_js/assets",
  "version": "0.9.22",
  "description": "Nexus asset pipeline — image optimization (AVIF/WebP), font injection, lazy loading",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./image": {
      "import": "./dist/image.js",
      "types": "./dist/image.d.ts"
    },
    "./fonts": {
      "import": "./dist/fonts.js",
      "types": "./dist/fonts.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "homepage": "https://nexusjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bierfor/nexus.git",
    "directory": "packages/assets"
  },
  "bugs": {
    "url": "https://github.com/bierfor/nexus/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bierfor084"
  },
  "keywords": [
    "nexus",
    "framework",
    "full-stack",
    "svelte",
    "islands",
    "ssr",
    "vite",
    "server-actions"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
