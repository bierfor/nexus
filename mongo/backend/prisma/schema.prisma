// Puro Flusso — MongoDB + Prisma 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  email      String   @unique
  source     String?
  /// Temas de interés (slugs cortos, coma-separados), p. ej. "productividad,minimalismo"
  interests  String?
  createdAt  DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Author {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  bio       String?
  avatarUrl String?
  articles  Article[]
}

model Tag {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String           @unique
  slug      String           @unique
  articles  TagsOnArticles[]
}

model Article {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String           @unique
  excerpt         String?
  content         String
  coverImage      String?
  coverImageAlt   String?
  readTimeMinutes Int?
  viewCount       Int              @default(0)
  published       Boolean          @default(false)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  authorId        String?          @db.ObjectId
  author          Author?          @relation(fields: [authorId], references: [id])
  tagLinks        TagsOnArticles[]
}

model TagsOnArticles {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  articleId String  @db.ObjectId
  tagId     String  @db.ObjectId
  article   Article @relation(fields: [articleId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@unique([articleId, tagId])
}

/// Bloques de hero por `slug` (p. ej. `home`). Solo `published` se sirve en la web pública.
model Hero {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  slug            String   @unique
  kicker          String?
  headline        String
  subheadline     String?
  body            String
  bodySecondary   String?
  imageUrl        String?
  footerCtaLabel  String?
  footerCtaHref   String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Token Bearer para integraciones (p. ej. bot IA). Formato: `pfbot_<keyId>.<secreto>`.
model BotApiToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  keyId      String    @unique
  secretHash String
  scopes     String[]
  enabled    Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

/// Noticias ultrabreves para el bloque "Noticias relámpago" de portada.
model FlashNews {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  summary     String
  sourceLabel String?
  sourceUrl   String?
  hack        String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
