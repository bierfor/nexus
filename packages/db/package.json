{
  "name": "@nexus_js/db",
  "version": "0.9.15",
  "description": "Nexus DB — BYOD thin provider adapter (Prisma, Drizzle, libSQL, Postgres.js)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/prisma": {
      "types": "./dist/adapters/prisma.d.ts",
      "import": "./dist/adapters/prisma.js"
    },
    "./adapters/drizzle": {
      "types": "./dist/adapters/drizzle.d.ts",
      "import": "./dist/adapters/drizzle.js"
    },
    "./adapters/libsql": {
      "types": "./dist/adapters/libsql.d.ts",
      "import": "./dist/adapters/libsql.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@nexus_js/runtime": "workspace:*",
    "@nexus_js/serialize": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "homepage": "https://nexusjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bierfor/nexus.git",
    "directory": "packages/db"
  },
  "bugs": {
    "url": "https://github.com/bierfor/nexus/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bierfor084"
  },
  "keywords": [
    "nexus",
    "framework",
    "full-stack",
    "svelte",
    "islands",
    "ssr",
    "vite",
    "server-actions"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
