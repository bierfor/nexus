# Copy to .env — `npm run dev` / `npm start` load it via Node (--env-file-if-exists=.env).
# Requires MongoDB listening on this host (default 127.0.0.1:27017).
# From repo root:  cd fin-sh && docker compose up -d
# Or install MongoDB locally / use MongoDB Atlas and set MONGODB_URI below.

PORT=4000
# Use either name — the API reads MONGODB_URI first, then DATABASE_URL (e.g. Atlas).
MONGODB_URI=mongodb://127.0.0.1:27017/finsh
# DATABASE_URL=mongodb+srv://user:pass@cluster/dbname

# Production (NODE_ENV=production): comma-separated browser origins for your public site.
# Example: https://fin.sh,https://www.fin.sh
# Development: origins are reflected automatically. Set FIN_SH_CORS_STRICT=1 to use the list below instead.
FIN_SH_CORS_ORIGIN=http://127.0.0.1:3050,http://localhost:3050
# FIN_SH_CORS_STRICT=1

# First admin (only created if no user with role admin exists)
FIN_SH_ADMIN_EMAIL=admin@example.com
FIN_SH_ADMIN_PASSWORD=change-me-8chars-min
# FIN_SH_ADMIN_NAME=Admin
