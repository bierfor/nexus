# GraphQL API (Apollo) — start with: pnpm --filter fin-sh-api dev
# Server-side fetch (SSR, actions): internal URL is fine (e.g. http://api:4000/graphql in Docker).
FIN_SH_GRAPHQL_URL=http://127.0.0.1:4000/graphql

# Browser (islands: login, register, dashboard ads). Must be a URL visitors can reach.
# Omit to reuse FIN_SH_GRAPHQL_URL. Set when the API is on another public host than SSR uses.
# FIN_SH_GRAPHQL_BROWSER_URL=https://api.example.com/graphql

# Optional: public URL of this Nexus app (short links in UI, canonical + JSON-LD SEO)
# Required for Stripe Checkout return URLs in production (must match the URL users see in the browser).
FIN_SH_PUBLIC_ORIGIN=http://127.0.0.1:3050

# --- Stripe (subscriptions) — fin-sh-api only; omit to disable billing mutations ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or Dashboard webhook endpoint
# Recurring subscription Price ids (Dashboard → Products → create monthly/yearly prices)
# STRIPE_PRICE_PREMIUM=price_...
# STRIPE_PRICE_BUSINESS=price_...
# Webhook URL on the API: POST http://<api-host>:4000/stripe/webhook (events: checkout.session.completed, customer.subscription.*)
# Enable Customer Portal in Stripe Dashboard → Settings → Billing → Customer portal.
