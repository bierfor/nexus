DATABASE_URL="mongodb://127.0.0.1:27017/smart_mag"
PORT=4000

# Producción: orígenes del front (coma), esquema + host, SIN barra final.
# Obligatorio si el navegador llama a este servidor desde otro dominio (GraphQL en cliente).
# CORS_ORIGINS=https://puroflusso.com,https://www.puroflusso.com

# Misma clave EXACTA que en frontend/.env.local → ADMIN_SECRET=...
# También: mismo valor que NEXUS_ADMIN_SECRET en nexus/news/.env (GraphQL Bearer + KPIs del panel /admin).
# Sin comillas o con comillas, pero el valor debe coincidir carácter a carácter tras normalizar.
ADMIN_SECRET=cambia-por-un-token-largo-aleatorio

# Misma cadena en frontend/.env.local (Next firma y verifica la cookie de sesión del admin)
ADMIN_JWT_SECRET=cambia-por-secreto-jwt-minimo-32-caracteres-aleatorios

# Crear o actualizar usuario admin (npm run create-admin o bloque final del seed)
ADMIN_BOOTSTRAP_EMAIL=admin@tudominio.com
ADMIN_BOOTSTRAP_PASSWORD=cambia-por-contraseña-larga

# Suscriptores del lead magnet (POST /leads desde Next /api/lead)

# Mismo valor en frontend/.env.local → HERO_PREVIEW_TOKEN (solo servidor; /preview/hero?token=...)
HERO_PREVIEW_TOKEN=

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
