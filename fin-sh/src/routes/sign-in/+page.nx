---
// nexus:pretext
export async function load(ctx) {
  return ctx.redirect('/login', 301);
}
---

<template>
  <p class="mono redirect-msg">Redirecting to <a href="/login">/login</a>…</p>
</template>

<style>
  .redirect-msg {
    font-family: var(--fin-mono, ui-monospace, monospace);
    font-size: 14px;
    color: var(--fin-muted, #666);
  }
  .redirect-msg a {
    color: var(--fin-fg, #000);
  }
</style>
