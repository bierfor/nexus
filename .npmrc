# pnpm workspace settings
# Public registry (explicit; avoids accidental corporate mirror).
# Note: do not set @nexus_js:registry here — pnpm injects npm_config__nexus_js_registry for child
# processes, and npm 11 warns "Unknown env config _nexus-js-registry" and may mis-handle publish auth.
registry=https://registry.npmjs.org/

# Publishing: default branch for `pnpm publish` git checks (overridden by --no-git-checks on `pnpm release`).
publish-branch=main

shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true

# Link workspace packages with symlinks
link-workspace-packages=true

# Don't install packages declared in devDependencies of non-root packages
# unless they are also in the workspace root devDependencies
shared-workspace-lockfile=true

# Avoid phantom dependencies
node-linker=isolated

