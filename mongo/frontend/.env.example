# =============================================================================
# Conexión front ↔ API (léelo entero en producción)
# =============================================================================
#
# El servidor Next (páginas, RSS, sitemap) usa BACKEND_URL.
# El navegador (p. ej. contador de vistas) necesita una variable NEXT_PUBLIC_*.
#
# En Vercel / Railway (front): define SIEMPRE:
#   BACKEND_URL=https://TU-API.railway.app
#   NEXT_PUBLIC_GRAPHQL_URL=https://TU-API.railway.app/graphql
# (misma API; la segunda es la que ve el cliente y debe ser HTTPS público.)
#
# Opcional: en lugar de NEXT_PUBLIC_GRAPHQL_URL puedes usar solo:
#   NEXT_PUBLIC_BACKEND_URL=https://TU-API.railway.app
# (el front añade /graphql en cliente.)

# --- Público (van al bundle JS; no pongas secretos) ---
NEXT_PUBLIC_GRAPHQL_URL=http://127.0.0.1:4000/graphql
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:4000

NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_HOME_HERO_SLUG=home
# HERO_PREVIEW_TOKEN=
# NEXT_PUBLIC_SOCIAL_PROOF_LEADS=1200
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=
# NEXT_PUBLIC_SOCIAL_X=
# NEXT_PUBLIC_SOCIAL_LINKEDIN=

# --- Solo servidor Next (Vercel / local) ---
BACKEND_URL=http://127.0.0.1:4000
ADMIN_SECRET=
ADMIN_JWT_SECRET=

# NEXT_STANDALONE=1

# Local: copia a .env.local
