# ── Copia este archivo a `.env` y rellena con los MISMOS valores que `mongo/backend/.env` ──
# El API debe estar en marcha: cd mongo/backend && npm run dev

# URL del GraphQL (CMS público + queries admin con Bearer)
NEXUS_GRAPHQL_URL=http://127.0.0.1:4000/graphql

# Bearer para GraphQL admin (KPIs del dashboard /admin, listas CRUD) — mismo valor que ADMIN_SECRET en mongo/backend/.env
# Si ves "Could not load CMS stats" en /admin: compara carácter a carácter con mongo/backend y reinicia ambos procesos.
# Alias aceptado: ADMIN_SECRET
NEXUS_ADMIN_SECRET=cambia-por-un-token-largo-aleatorio

# Secreto para firmar/verificar el JWT del login (cookie `pf_admin_token`, rutas /admin, nav SSR)
# Mínimo 32 caracteres. Mismo valor que ADMIN_JWT_SECRET en mongo/backend
# Alias aceptados: ADMIN_JWT_SECRET
NEXUS_ADMIN_JWT_SECRET=cambia-por-secreto-jwt-minimo-32-caracteres-aleatorios

# Opcional: bloque hero en portada (seed suele usar `home`)
# NEXUS_HERO_SLUG=home
